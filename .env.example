# Copy this file to .env and fill in your actual values
# Never commit .env file with real credentials to version control

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=False
ENV=development

# LLM Configuration
OPENAI_API_KEY=sk-your-actual-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview
# For vLLM/LiteLLM: uncomment and set the base URL
# VLLM_BASE_URL=http://vllm:8001/v1
# VLLM_BASE_URL=http://litellm:4000/v1

# Fallback LLM Configuration (Claude Sonnet via LiteLLM)
ANTHROPIC_API_KEY=sk-ant-dummy-key-replace-me
FALLBACK_MODEL=claude-sonnet-4-6-20250514

# LangSmith Tracing Configuration
# Get your API key from https://smith.langchain.com/settings
LANGSMITH_ENABLED=true
LANGCHAIN_API_KEY=lsv2_pt_dummy_langsmith_api_key_replace_me
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=customer-support-email-agent
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# Email Configuration
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_ADDRESS=your-email@gmail.com
EMAIL_PASSWORD=your-app-password-or-password
EMAIL_FROM_NAME=Customer Support

# Database Configuration
DATABASE_URL=sqlite:///./customer_support.db
# For PostgreSQL use: postgresql://user:password@localhost:5432/customer_support_db

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Email Processing Configuration
EMAIL_CHECK_INTERVAL=300
MAX_EMAILS_PER_BATCH=10
EMAIL_RESPONSE_TIMEOUT=30

# Vector Store Configuration
VECTOR_STORE_PATH=./data/vectors
